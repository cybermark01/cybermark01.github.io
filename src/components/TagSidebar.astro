---
interface Props {
  tags: { name: string; count: number }[];
  activeTag: string | null;
  totalPosts?: number;
}

const { tags, activeTag, totalPosts } = Astro.props;

const tagColorMap: Record<string, string> = {
  'cybersecurity': 'var(--c-cyber)',
  'AI': 'var(--c-ai)',
  'cryptography': 'var(--c-crypto)',
  'crittografia': 'var(--c-crypto)',
  'machine-learning': 'var(--c-ml)',
  'reverse-engineering': 'var(--c-re)',
  'physics': 'var(--c-phys)',
  'fisica': 'var(--c-phys)',
  'privacy': 'var(--c-priv)',
  'llm': 'var(--c-llm)',
  'space': 'var(--c-space)',
  'spazio': 'var(--c-space)',
  'hardware': 'var(--c-re)',
};
function tagColor(name: string): string {
  return tagColorMap[name] ?? 'var(--accent)';
}

const displayCount = totalPosts ?? tags.reduce((s, t) => s + t.count, 0);
---

<nav class="tag-sidebar">
  <p class="tag-label">Filter by tag</p>
  <ul class="tag-list">
    {tags.map(({ name, count }) => (
      <li>
        <a
          href={`/tag/${name}`}
          class:list={['tag-item', activeTag === name ? 'tag-active' : '']}
          data-tag={name}
        >
          <span class="tag-name-row">
            <span class="tag-dot" style={`background:${tagColor(name)};`}></span>
            {name}
          </span>
          <span class="tag-count">{count}</span>
        </a>
      </li>
    ))}
  </ul>
  <div class="tag-footer">
    <span style="color:var(--muted);">{displayCount}</span> posts
  </div>
</nav>

<style>
  .tag-sidebar {
    width: 220px;
    flex-shrink: 0;
    position: sticky;
    top: 96px;
  }

  .tag-label {
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: var(--faint);
    margin: 0 0 0.75rem;
    padding-left: 10px;
  }

  .tag-list {
    display: flex;
    flex-direction: column;
    gap: 1px;
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .tag-item {
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
    padding: 7px 10px;
    border-radius: 8px;
    font-family: var(--mono);
    font-size: 13px;
    color: var(--muted);
    text-decoration: none;
    transition: background .18s var(--ease), color .18s var(--ease), transform .18s var(--spring);
  }

  .tag-item:hover {
    background: var(--accent-soft);
    color: var(--accent);
    transform: translateX(3px);
  }

  .tag-active {
    color: var(--accent);
    background: var(--accent-soft);
  }

  .tag-name-row {
    display: flex;
    align-items: center;
    gap: 8px;
    min-width: 0;
  }

  .tag-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    flex: none;
  }

  .tag-count {
    font-size: 11.5px;
    color: var(--faint);
    font-variant-numeric: tabular-nums;
  }

  .tag-footer {
    margin-top: 28px;
    padding: 14px 12px;
    border-top: 1px solid var(--line);
    font-family: var(--mono);
    font-size: 11.5px;
    line-height: 1.7;
    color: var(--faint);
  }

  @media (max-width: 768px) {
    .tag-sidebar {
      width: 100%;
      position: static;
    }

    .tag-list {
      flex-direction: row;
      flex-wrap: wrap;
      gap: 6px;
    }

    .tag-item {
      white-space: nowrap;
      border: 1px solid var(--line);
      border-radius: 20px;
      padding: 5px 12px;
    }

    .tag-count {
      display: none;
    }

    .tag-footer {
      display: none;
    }
  }
</style>
