---
import Base from '../layouts/Base.astro';
---

<Base title="Portfolio — cybermark01" description="Cybersecurity projects by cybermark01">
  <div style="max-width:760px;margin:0 auto;padding:56px 32px 96px;animation:pageIn .5s var(--ease) both;">
    <div style="font-family:var(--mono);font-size:11px;letter-spacing:1.5px;color:var(--faint);text-transform:uppercase;margin-bottom:14px;">Portfolio</div>
    <h1 style="margin:0 0 18px;font-family:var(--mono);font-size:34px;font-weight:700;letter-spacing:-1px;color:var(--text);">Things I've built</h1>
    <p style="margin:0 0 48px;font-family:var(--serif);font-size:17px;line-height:1.6;color:var(--muted);max-width:54ch;">Projects coming soon.</p>
  </div>
</Base>
