---
import Base from '../layouts/Base.astro';
---

<Base title="About — cybermark01" description="About cybermark01">
  <div style="max-width:640px;margin:0 auto;padding:56px 32px 96px;animation:pageIn .5s var(--ease) both;">
    <div style="font-family:var(--mono);font-size:11px;letter-spacing:1.5px;color:var(--faint);text-transform:uppercase;margin-bottom:14px;">About</div>
    <h1 style="margin:0 0 28px;font-family:var(--display);font-size:clamp(28px,7vw,40px);font-weight:700;letter-spacing:0.5px;color:var(--text);">cybermark<span style="color:var(--accent);">_</span></h1>
    <p style="font-family:var(--serif);font-size:18px;line-height:1.72;color:var(--muted);">Under construction — coming soon.</p>
  </div>
</Base>
