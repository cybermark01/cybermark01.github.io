---
import Base from '../layouts/Base.astro';
import { bookmarks } from '../data/bookmarks';

function getDomain(url: string): string {
  try {
    return new URL(url).hostname;
  } catch {
    return url;
  }
}
---

<Base title="Bookmarks — cybermark01" description="Blue team tools curated by cybermark01">
  <div class="bm-outer">
    <div class="bm-adv bm-adv-left"></div>

    <div class="bm-content">
      <div class="bm-intro" data-tilt>
        <span class="sheen"></span>
        <div style="margin:0 0 10px;font-family:var(--mono);font-size:30px;font-weight:700;letter-spacing:-1px;color:var(--text);">Bookmarks</div>
        A curated list of blue team tools I use and trust — organized by category.
      </div>

      <div class="bm-adv-inline"></div>

      {bookmarks.map((category, i) => (
        <>
          <section class="bm-section">
            <h2 class="bm-cat-title">{category.name}</h2>
            <div class="bm-grid">
              {category.tools.map((tool) => (
                <div class="bm-card">
                  <img
                    src={`https://www.google.com/s2/favicons?domain=${getDomain(tool.url)}&sz=32`}
                    alt={tool.name}
                    width="32"
                    height="32"
                    class="bm-favicon"
                  />
                  <div class="bm-tool-name">{tool.name}</div>
                  <div class="bm-tool-desc">{tool.description}</div>
                  <a
                    href={tool.url}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="bm-btn"
                  >GO</a>
                </div>
              ))}
            </div>
          </section>
          {i === 1 && <div class="bm-adv-inline"></div>}
        </>
      ))}
    </div>

    <div class="bm-adv bm-adv-right"></div>
  </div>
</Base>

<style>
  .bm-outer {
    max-width: 1200px;
    margin: 0 auto;
    padding: 40px 32px 72px;
    display: grid;
    grid-template-columns: 160px 1fr 160px;
    gap: 32px;
    align-items: start;
    animation: pageIn .35s var(--ease) both;
  }

  .bm-adv {
    width: 160px;
    min-height: 200px;
    border: 1px dashed var(--line);
    border-radius: 8px;
    background: transparent;
    display: flex;
    align-items: center;
    justify-content: center;
    position: sticky;
    top: 80px;
  }

  .bm-adv span {
    font-size: 11px;
    color: var(--faint);
    font-family: var(--mono);
  }

  .bm-content {
    min-width: 0;
    max-width: 720px;
    justify-self: center;
    width: 100%;
  }

  .bm-intro {
    position: relative;
    background: var(--surface);
    border: 1px solid var(--line);
    border-radius: 20px;
    padding: 30px;
    box-shadow: var(--shadow-md);
    font-size: 15px;
    font-weight: 600;
    color: var(--text);
    font-family: var(--mono);
    letter-spacing: -0.3px;
    line-height: 1.4;
    margin-bottom: 40px;
    overflow: hidden;
    transform-style: preserve-3d;
    will-change: transform;
    transition: transform .45s var(--spring), box-shadow .45s var(--ease), border-color .2s var(--ease);
  }

  .bm-intro:hover {
    border-color: var(--line-strong);
    box-shadow: var(--shadow-lg);
  }

  .bm-intro .sheen {
    position: absolute;
    inset: 0;
    border-radius: inherit;
    pointer-events: none;
    background: radial-gradient(340px circle at var(--mx, 50%) var(--my, 50%), var(--sheen-color, rgba(255,255,255,.40)), rgba(255,255,255,0) 60%);
    opacity: var(--sheen, 0);
    transition: opacity .3s var(--ease);
  }

  .bm-section {
    margin-bottom: 40px;
  }

  .bm-cat-title {
    font-family: var(--mono);
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 0.5px;
    color: var(--text);
    text-transform: uppercase;
    margin: 0 0 16px;
    padding-bottom: 8px;
    border-bottom: 1px solid var(--line);
  }

  .bm-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(160px, 1fr));
    gap: 12px;
  }

  .bm-card {
    background: var(--surface);
    border: 1px solid var(--line);
    border-radius: 10px;
    padding: 16px 12px;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    transition: border-color .2s var(--ease);
  }

  .bm-card:hover {
    border-color: var(--accent);
  }

  .bm-favicon {
    width: 32px;
    height: 32px;
    margin-bottom: 8px;
    border-radius: 4px;
  }

  .bm-tool-name {
    font-family: var(--mono);
    font-size: 14px;
    font-weight: 600;
    color: var(--text);
    margin-bottom: 6px;
  }

  .bm-tool-desc {
    font-family: var(--sans);
    font-size: 12px;
    color: var(--faint);
    line-height: 1.45;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    flex: 1;
    margin-bottom: 12px;
  }

  .bm-btn {
    background: var(--accent);
    color: white;
    border: none;
    border-radius: 6px;
    padding: 6px 0;
    width: 100%;
    font-size: 12px;
    font-family: var(--mono);
    cursor: pointer;
    text-decoration: none;
    display: block;
    text-align: center;
    transition: opacity .15s var(--ease);
    margin-top: auto;
  }

  .bm-btn:hover {
    opacity: 0.85;
  }

  .bm-adv-inline {
    display: none;
  }

  @media (max-width: 900px) {
    .bm-outer {
      grid-template-columns: 1fr;
      padding: 24px 16px 48px;
      gap: 0;
    }

    .bm-adv-left,
    .bm-adv-right {
      display: none;
    }

    .bm-adv-inline {
      display: flex;
      align-items: center;
      justify-content: center;
      min-height: 80px;
      border: 1px dashed var(--line);
      border-radius: 8px;
      margin-bottom: 32px;
      color: var(--faint);
      font-size: 11px;
      font-family: var(--mono);
    }
  }
</style>

<script is:inline>
  document.querySelectorAll('[data-tilt]').forEach(el => {
    el.addEventListener('mousemove', e => {
      const r = el.getBoundingClientRect();
      const px = (e.clientX - r.left) / r.width - 0.5;
      const py = (e.clientY - r.top) / r.height - 0.5;
      el.style.transform = `perspective(950px) rotateX(${(-py * 4.5).toFixed(2)}deg) rotateY(${(px * 6).toFixed(2)}deg) translateY(-7px) scale(1.014)`;
      el.style.setProperty('--mx', (px * 100 + 50).toFixed(1) + '%');
      el.style.setProperty('--my', (py * 100 + 50).toFixed(1) + '%');
      el.style.setProperty('--sheen', '1');
    });
    el.addEventListener('mouseleave', () => {
      el.style.transform = '';
      el.style.setProperty('--sheen', '0');
    });
  });
</script>
